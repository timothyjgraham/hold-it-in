{
  "name": "hold-it-in",
  "version": "0.1.0",
  "description": "A tower defense game where you defend YOUR toilet from an endless horde of desperate people",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "compress-audio": "bash scripts/compress-audio.sh",
